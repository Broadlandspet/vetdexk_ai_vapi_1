{
  "name": "broadlands-pet-hospital-api",
  "version": "2.0.0",
  "description": "Broadlands Pet Hospital - AI Voice Appointment System with Google Calendar & Gmail Integration",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "pm2-start": "pm2 start src/app.js --name broadlands-pet-api",
    "pm2-stop": "pm2 stop broadlands-pet-api",
    "pm2-restart": "pm2 restart broadlands-pet-api",
    "pm2-logs": "pm2 logs broadlands-pet-api",
    "pm2-status": "pm2 status",
    "db:migrate": "node scripts/setup-db.js",
    "db:migrate:appointment": "node scripts/migrate-appointment.js",
    "db:seed": "node scripts/seed-working-hours.js",
    "test": "echo \"No tests configured yet\" && exit 0",
    "test:calendar": "node scripts/test-calendar.js",
    "test:gmail": "node scripts/test-gmail.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "googleapis": "^128.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "moment-timezone": "^0.6.2",
    "mysql2": "^3.9.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.7",
    "pg": "^8.20.0",
    "twilio": "^4.19.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "pet-hospital",
    "appointment-booking",
    "google-calendar",
    "gmail-api",
    "twilio",
    "vapi",
    "voice-ai"
  ],
  "author": "Broadlands Pet Hospital",
  "license": "ISC"
}
